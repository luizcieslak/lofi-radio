# Server Configuration
PORT=5634

# Admin API Key (required for upload/edit/delete operations)
# Generate a secure random key for production
RADIO_API_KEY=your-secret-api-key-here

# For production deployments, this port will be automatically set by:
# - Railway: Provides PORT env var
# - Docker: Set via docker-compose.yml or docker run -e PORT=...
# - Local dev: Uses default 5634 if not set

# Admin API Key (for uploading songs via /admin/upload endpoint)
# Generate a secure random key for production use
RADIO_API_KEY=your-secure-api-key-here
